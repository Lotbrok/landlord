# ── DATABASE ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=landlord
DB_USER=landlord_user
DB_PASSWORD=your_secure_password_here

# ── AUTH ──────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── SERVER ────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── GAME ──────────────────────────────────────────
# How often income is credited to players (seconds)
INCOME_TICK_SECONDS=10
# Starting balance for new players
STARTING_BALANCE=10000
